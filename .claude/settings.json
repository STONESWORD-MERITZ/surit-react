{
  "permissions": {
    "allow": [
      "Read",
      "Edit(backend/**)",
      "Edit(src/**)",
      "Edit(public/**)",
      "Edit(*.md)",
      "Edit(*.json)",
      "Edit(*.ts)",
      "Edit(*.tsx)",
      "Edit(*.css)",
      "Write(backend/**)",
      "Write(src/**)",

      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(pwd)",
      "Bash(cd *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(echo *)",

      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git pull *)",
      "Bash(git stash *)",

      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(npm list *)",
      "Bash(npx *)",

      "Bash(pip install *)",
      "Bash(pip list *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(uvicorn *)",

      "Bash(curl *)"
    ],

    "ask": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(npm publish *)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(*.env)",
      "Write(.env)"
    ],

    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(*.pem)",
      "Read(**/credentials/**)",
      "Read(**/secrets/**)"
    ]
  }
}